{
  "name": "ai-admin-assistant",
  "version": "0.1.0",
  "description": "AI Admin Assistant - Google Calendar agent via natural language",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "nest build",
    "start": "node dist/main.js",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:push": "prisma db push",
    "db:seed": "prisma db seed",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "langgraph:dev": "npx @langchain/langgraph-cli dev",
    "lint": "eslint '{src,test}/**/*.ts'",
    "lint:fix": "eslint '{src,test}/**/*.ts' --fix",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@langchain/core": "^1.1.36",
    "@langchain/langgraph": "^1.2.5",
    "@langchain/openai": "^1.3.1",
    "@nestjs/common": "^11.1.12",
    "@nestjs/config": "^4.0.2",
    "@nestjs/core": "^11.1.12",
    "@nestjs/platform-fastify": "^11.1.12",
    "@prisma/client": "6.19.2",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.3",
    "googleapis": "^171.4.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.16",
    "@nestjs/schematics": "^11.0.5",
    "@types/node": "^22.0.0",
    "prisma": "6.19.2",
    "typescript": "^5.7.0"
  }
}
