{
  "name": "ai-admin-assistant",
  "version": "0.1.0",
  "description": "AI Admin Assistant - Google Calendar agent via natural language",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "build": "tsc",
    "lint": "eslint '{src,test}/**/*.ts'",
    "lint:fix": "eslint '{src,test}/**/*.ts' --fix",
    "type-check": "tsc --noEmit",
    "langgraph:serve": "npx @langchain/langgraph-cli dev",
    "auth:google": "node --experimental-strip-types scripts/google-auth.ts",
    "test": "node --experimental-strip-types --env-file .env --test tests/**/*.test.ts",
    "test:dev": "node --experimental-strip-types --env-file .env --test --watch tests/**/*.test.ts"
  },
  "dependencies": {
    "@langchain/anthropic": "^1.3.25",
    "@langchain/core": "^1.1.36",
    "@langchain/langgraph": "^1.2.5",
    "@langchain/openai": "^1.3.1",
    "dotenv": "^17.3.1",
    "googleapis": "^171.4.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.7.0"
  }
}
