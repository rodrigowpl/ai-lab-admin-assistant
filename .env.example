DATABASE_URL=

# Google Calendar OAuth2
# Run "yarn auth:google" after setting client ID and secret to authenticate
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_DEFAULT_CALENDAR_ID=primary

# LLM (OpenRouter)
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
NLP_MODEL=gpt-4o-mini

# LangSmith
LANGSMITH_TRACING=true
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=ai-admin-assistant
LANGSMITH_ENDPOINT=

# Defaults
DEFAULT_DURATION_MINUTES=30
DEFAULT_CALENDAR_NAME=Work
